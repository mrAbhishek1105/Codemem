{
  "name": "codemem",
  "version": "0.1.0",
  "description": "AI-agnostic local memory layer for codebases. Index once, remember forever, switch AI freely.",
  "type": "module",
  "bin": {
    "codemem": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "boxen": "^8.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "fastify": "^4.28.0",
    "ignore": "^5.3.2",
    "lru-cache": "^10.4.3",
    "ora": "^8.1.0",
    "p-limit": "^5.0.0",
    "vectra": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "overrides": {
    "onnxruntime-node": "file:./node_ort_shim"
  }
}
